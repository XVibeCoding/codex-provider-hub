{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Provider Hub",
  "version": "0.1.0",
  "identifier": "com.codex.providerhub",
  "build": { "beforeDevCommand": "npm run dev", "devUrl": "http://localhost:1420", "beforeBuildCommand": "npm run build", "beforeBundleCommand": "npm run build:cli", "frontendDist": "../dist" },
  "app": { "windows": [{ "title": "Codex Provider Hub", "width": 1280, "height": 900, "minWidth": 1040, "minHeight": 760, "center": true, "resizable": true }], "security": { "csp": null } },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
